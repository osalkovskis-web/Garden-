# Dārza IoT sistēmas konfigurācija — kopēt uz .env un aizpildīt
# NEKAD nepievienot .env git repozitorijam!

# ── MQTT brokeris (HiveMQ free tier) ─────────────────────────────────────────
# Reģistrēties: https://console.hivemq.cloud → Create free cluster
MQTT_HOST=YOUR-ID.s2.eu.hivemq.cloud
MQTT_PORT=1883
MQTT_USER=garden_gw
MQTT_PASS=CHANGE_ME_STRONG_PASSWORD

# ── SIM karte ────────────────────────────────────────────────────────────────
# LMT: APN=internet, user/pass tukši
# Tele2: APN=internet.tele2.lv, user/pass tukši
APN=internet
SIM_USER=
SIM_PASS=

# ── Web serveris (Pixel 9 Termux) ────────────────────────────────────────────
# Šos mainīgos izmanto web_server.py
# Palaišana: MQTT_HOST=xxx MQTT_USER=xxx MQTT_PASS=xxx python3 web_server.py
